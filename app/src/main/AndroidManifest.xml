<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".PiperTtsApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PiperTTS">

        <!-- Main settings activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Voice Manager activity -->
        <activity
            android:name=".ui.VoiceListActivity"
            android:exported="false"
            android:label="@string/voice_manager_title" />

        <!-- TTS Engine Settings activity (launched from system TTS settings gear icon) -->
        <activity
            android:name=".ui.TtsSettingsActivity"
            android:exported="true"
            android:label="@string/tts_settings_title" />

        <!--
            CHECK_TTS_DATA handler — Android sends this intent to verify the engine
            has voice data available. Without this, the engine will NOT appear in
            TTS settings on many Android versions.

            CATEGORY_DEFAULT is required so the intent can be resolved implicitly.
        -->
        <activity
            android:name=".ui.CheckVoiceData"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
            INSTALL_TTS_DATA handler — Android sends this when voice data needs
            to be installed. Redirects to the Voice Manager.
        -->
        <activity
            android:name=".ui.InstallVoiceData"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.speech.tts.engine.INSTALL_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
            GET_SAMPLE_TEXT handler — Android sends this to get sample text for
            the "Listen to an example" button in TTS settings.
        -->
        <activity
            android:name=".ui.GetSampleText"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.speech.tts.engine.GET_SAMPLE_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- System TTS Engine Service -->
        <service
            android:name=".service.PiperTtsService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_TEXT_TO_SPEECH_SERVICE">
            <intent-filter>
                <action android:name="android.intent.action.TTS_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <!-- FileProvider for sharing recorded WAV files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
